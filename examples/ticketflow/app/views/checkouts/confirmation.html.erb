<% content_for :title, "Order Confirmed!" %>

<div class="max-w-3xl mx-auto px-4 py-12">
  <!-- Success header -->
  <div class="text-center mb-10">
    <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="text-green-500" style="width:2.5rem;height:2.5rem;flex-shrink:0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
      </svg>
    </div>
    <h1 class="text-3xl font-extrabold text-gray-900 mb-2">You're going!</h1>
    <p class="text-gray-500 text-lg">Your tickets have been confirmed and "delivered" to <strong><%= @order.email %></strong></p>
  </div>

  <!-- Order summary card -->
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 mb-6">
    <div class="flex items-start justify-between mb-6">
      <div>
        <h2 class="text-xl font-bold text-gray-900"><%= @order.event.title %></h2>
        <p class="text-gray-500 text-sm mt-1"><%= @order.event.starts_at.strftime("%B %d, %Y at %I:%M %p") %></p>
        <% if @order.event.venue.present? %>
          <p class="text-gray-500 text-sm"><%= @order.event.venue %></p>
        <% end %>
      </div>
      <div class="text-right">
        <p class="text-xs text-gray-400 uppercase tracking-wide">Order Total</p>
        <p class="text-2xl font-bold text-gray-900">$<%= "%.2f" % @order.total %></p>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-4 border-t border-gray-50 text-sm">
      <div>
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Order Reference</p>
        <p class="font-mono font-semibold text-gray-700"><%= @order.payment_reference %></p>
      </div>
      <div>
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Attendee</p>
        <p class="font-semibold text-gray-700"><%= @order.name %></p>
      </div>
      <% if @order.discount_cents > 0 %>
        <div>
          <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Discount Applied</p>
          <p class="font-semibold text-green-600">-$<%= "%.2f" % @order.discount %></p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Tickets -->
  <div class="space-y-4">
    <h2 class="text-xl font-bold text-gray-900">Your Tickets (<%= @tickets.count %>)</h2>
    <% @tickets.each_with_index do |ticket, i| %>
      <div class="bg-white rounded-2xl shadow-sm overflow-hidden border border-gray-100">
        <div class="flex">
          <!-- Color stripe -->
          <div class="w-4 flex-shrink-0" style="background: <%= @order.event.cover_color %>"></div>

          <!-- Ticket content -->
          <div class="flex-1 p-6">
            <div class="flex items-start justify-between">
              <div>
                <p class="text-xs text-gray-400 uppercase tracking-widest mb-1">Ticket <%= i + 1 %> of <%= @tickets.count %></p>
                <h3 class="text-lg font-bold text-gray-900"><%= ticket.ticket_type.name %></h3>
                <p class="text-gray-500 text-sm"><%= @order.event.title %></p>
                <p class="text-gray-400 text-xs mt-1"><%= @order.event.starts_at.strftime("%B %d, %Y") %></p>
              </div>
              <div class="text-right">
                <% if ticket.delivered? %>
                  <span class="inline-block bg-green-100 text-green-700 text-xs font-semibold px-3 py-1 rounded-full">Delivered</span>
                <% end %>
              </div>
            </div>

            <!-- Token -->
            <div class="mt-4 pt-4 border-t border-dashed border-gray-200 flex items-center justify-between">
              <div>
                <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Ticket ID</p>
                <p class="font-mono text-lg font-bold text-indigo-600 tracking-wider"><%= ticket.token %></p>
              </div>
              <div class="text-right text-xs text-gray-400">
                <p><%= ticket.attendee_name %></p>
                <p><%= ticket.attendee_email %></p>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="mt-8 text-center">
    <%= link_to events_path, class: "text-indigo-600 hover:text-indigo-800 font-semibold" do %>
      Browse more events &rarr;
    <% end %>
  </div>
</div>
