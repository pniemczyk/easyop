<% content_for :title, "Buy Tickets — #{@event.title}" %>

<div class="bg-gray-50 min-h-screen py-10">
  <div class="max-w-4xl mx-auto px-4">
    <!-- Back link -->
    <div class="mb-6">
      <%= link_to event_path(@event.slug), class: "text-sm text-gray-500 hover:text-indigo-600 flex items-center gap-1 transition-colors" do %>
        <svg style="width:1rem;height:1rem;flex-shrink:0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back to event
      <% end %>
    </div>

    <h1 class="text-3xl font-bold text-gray-900 mb-2">Buy Tickets</h1>
    <p class="text-gray-500 mb-8"><%= @event.title %> &mdash; <%= @event.starts_at.strftime("%B %d, %Y") %></p>

    <% alert_msg = flash.now[:alert] || flash[:alert] %>
    <% if alert_msg %>
      <% payment_error = alert_msg.to_s.match?(/card|funds|cvc|expired|declined|transaction|processing error|lost|velocity/i) %>
      <% if payment_error %>
        <div class="bg-red-50 border border-red-200 rounded-xl px-5 py-4 mb-6 flex gap-4">
          <div class="flex-shrink-0 mt-0.5">
            <svg class="text-red-500" style="width:1.25rem;height:1.25rem;flex-shrink:0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-red-800">Payment declined</p>
            <p class="text-sm text-red-700 mt-0.5"><%= alert_msg %></p>
            <p class="text-xs text-red-500 mt-2">Please try again — payment results are randomised in this demo.</p>
          </div>
        </div>
      <% else %>
        <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg mb-6 text-sm">
          <%= alert_msg %>
        </div>
      <% end %>
    <% end %>

    <%= form_with url: event_checkouts_path(@event.slug), method: :post, class: "space-y-6", id: "checkout-form" do |f| %>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Left: Ticket selection + details -->
        <div class="lg:col-span-2 space-y-6">
          <!-- Ticket selection -->
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
            <h2 class="text-lg font-bold text-gray-900 mb-4">Select Tickets</h2>
            <div class="space-y-4" id="ticket-selector">
              <% @ticket_types.each do |tt| %>
                <div class="flex items-center justify-between py-4 border-b border-gray-50 last:border-0">
                  <div class="flex-1">
                    <h3 class="font-semibold text-gray-900"><%= tt.name %></h3>
                    <% if tt.description.present? %>
                      <p class="text-sm text-gray-500"><%= tt.description %></p>
                    <% end %>
                    <p class="text-indigo-600 font-bold mt-1">
                      <% if tt.price_cents == 0 %>Free<% else %>$<%= "%.2f" % tt.price %><% end %>
                    </p>
                  </div>
                  <div class="flex items-center gap-3 ml-4">
                    <button type="button" onclick="changeQty('<%= tt.id %>', -1)"
                            class="w-8 h-8 bg-gray-100 hover:bg-gray-200 rounded-full flex items-center justify-center text-gray-700 font-bold transition-colors">
                      &minus;
                    </button>
                    <input type="number"
                           name="cart[<%= tt.id %>]"
                           value="0"
                           min="0"
                           max="<%= tt.available_count %>"
                           class="w-12 text-center font-semibold text-gray-900 border border-gray-200 rounded-lg py-1 qty-input"
                           data-price="<%= tt.price_cents %>"
                           data-ticket-id="<%= tt.id %>"
                           data-name="<%= tt.name %>"
                           onchange="updateSummary()">
                    <button type="button" onclick="changeQty('<%= tt.id %>', 1)"
                            class="w-8 h-8 bg-indigo-100 hover:bg-indigo-200 rounded-full flex items-center justify-center text-indigo-700 font-bold transition-colors">
                      +
                    </button>
                  </div>
                </div>
              <% end %>
            </div>
          </div>

          <!-- Personal details -->
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
            <h2 class="text-lg font-bold text-gray-900 mb-4">Your Details</h2>
            <div class="grid grid-cols-1 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
                <input type="text" name="name" required placeholder="Jane Smith"
                       class="w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
                <input type="email" name="email" required placeholder="jane@example.com"
                       class="w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                <p class="text-xs text-gray-400 mt-1">Your tickets will be sent to this address</p>
              </div>
            </div>
          </div>

          <!-- Discount code -->
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
            <h2 class="text-lg font-bold text-gray-900 mb-4">Discount Code</h2>
            <div class="flex gap-3">
              <input type="text" name="coupon_code" placeholder="Enter code (e.g. SAVE10)"
                     class="flex-1 border border-gray-200 rounded-xl px-4 py-3 text-gray-900 placeholder-gray-400 uppercase focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm font-mono">
              <div class="flex items-center bg-gray-50 border border-gray-200 rounded-xl px-3 py-2 text-xs text-gray-500 whitespace-nowrap">
                Applied at checkout
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Order summary -->
        <div>
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sticky top-24">
            <h2 class="text-lg font-bold text-gray-900 mb-4">Order Summary</h2>
            <div id="summary-items" class="space-y-2 mb-4 min-h-[60px]">
              <p class="text-sm text-gray-400 italic" id="no-tickets-msg">No tickets selected</p>
            </div>
            <div class="border-t border-gray-100 pt-4 space-y-2">
              <div class="flex justify-between text-sm text-gray-500">
                <span>Subtotal</span>
                <span id="subtotal-display">$0.00</span>
              </div>
              <div class="flex justify-between text-sm text-gray-500">
                <span>Discount</span>
                <span class="text-green-600" id="discount-display">-</span>
              </div>
              <div class="flex justify-between font-bold text-gray-900 text-base pt-2 border-t border-gray-100">
                <span>Total</span>
                <span id="total-display">$0.00</span>
              </div>
            </div>

            <button type="submit" id="submit-btn"
                    class="w-full mt-6 bg-indigo-600 hover:bg-indigo-700 disabled:bg-gray-300 disabled:cursor-not-allowed text-white font-bold py-4 rounded-xl text-base transition-colors flex items-center justify-center gap-2"
                    disabled>
              <svg id="spinner" class="hidden animate-spin text-white" style="width:1rem;height:1rem;flex-shrink:0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
              </svg>
              <span id="submit-label">Complete Purchase</span>
            </button>
            <p class="text-xs text-center text-gray-400 mt-3">
              Demo mode &mdash; 75% success rate &middot; check
              <%= link_to "operation logs", admin_operation_logs_path(category: "orders"), class: "underline hover:text-indigo-500", target: "_blank" %>
              for payment details
            </p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<script>
  function changeQty(id, delta) {
    const input = document.querySelector(`input[data-ticket-id="${id}"]`);
    if (!input) return;
    const max = parseInt(input.getAttribute('max') || '999');
    let val = parseInt(input.value || '0') + delta;
    input.value = Math.max(0, Math.min(max, val));
    updateSummary();
  }

  function updateSummary() {
    const inputs = document.querySelectorAll('.qty-input');
    let subtotal = 0;
    let hasTickets = false;
    let summaryHtml = '';

    inputs.forEach(function(input) {
      const qty = parseInt(input.value || '0');
      const price = parseInt(input.getAttribute('data-price') || '0');
      if (qty > 0) {
        hasTickets = true;
        subtotal += price * qty;
        const label = input.dataset.name || 'Ticket';
        summaryHtml += `<div class="flex justify-between text-sm text-gray-700">
          <span>${label} x${qty}</span>
          <span class="font-medium">$${(price * qty / 100).toFixed(2)}</span>
        </div>`;
      }
    });

    document.getElementById('summary-items').innerHTML = hasTickets ? summaryHtml : '<p class="text-sm text-gray-400 italic" id="no-tickets-msg">No tickets selected</p>';
    document.getElementById('subtotal-display').textContent = '$' + (subtotal / 100).toFixed(2);
    document.getElementById('total-display').textContent = '$' + (subtotal / 100).toFixed(2);
    document.getElementById('discount-display').textContent = '-';
    document.getElementById('submit-btn').disabled = !hasTickets;
  }

  document.addEventListener('DOMContentLoaded', updateSummary);

  document.getElementById('checkout-form').addEventListener('submit', function() {
    const btn = document.getElementById('submit-btn');
    const label = document.getElementById('submit-label');
    const spinner = document.getElementById('spinner');
    btn.disabled = true;
    spinner.classList.remove('hidden');
    label.textContent = 'Processing payment…';
  });
</script>
