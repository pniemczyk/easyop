<% content_for :page_title, "Order ##{@order.id}" %>

<div class="flex items-center justify-between mb-6">
  <%= link_to "← All orders", admin_orders_path, class: "text-sm text-gray-500 hover:text-indigo-600" %>
  <% if @order.status == "paid" %>
    <%= button_to "Refund Order", refund_admin_order_path(@order), method: :post,
        data: { turbo_confirm: "Refund this order? This will cancel all tickets." },
        class: "text-sm bg-red-50 hover:bg-red-100 text-red-600 font-semibold px-4 py-2 rounded-lg transition-colors" %>
  <% end %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
  <!-- Order details -->
  <div class="lg:col-span-2 space-y-6">
    <!-- Order summary -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
      <h2 class="text-base font-bold text-gray-900 mb-4">Order Details</h2>
      <div class="grid grid-cols-2 gap-4 text-sm">
        <div>
          <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Customer</p>
          <p class="font-semibold text-gray-900"><%= @order.name %></p>
          <p class="text-gray-500"><%= @order.email %></p>
        </div>
        <div>
          <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Event</p>
          <p class="font-semibold text-gray-900"><%= @order.event.title %></p>
          <p class="text-gray-500"><%= @order.event.starts_at.strftime("%B %d, %Y") %></p>
        </div>
        <div>
          <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Status</p>
          <% status_classes = { "paid" => "bg-green-50 text-green-700", "pending" => "bg-yellow-50 text-yellow-700", "refunded" => "bg-red-50 text-red-700", "cancelled" => "bg-gray-100 text-gray-500" } %>
          <span class="text-xs font-semibold px-3 py-1 rounded-full <%= status_classes[@order.status] %>">
            <%= @order.status.capitalize %>
          </span>
        </div>
        <div>
          <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Payment Reference</p>
          <p class="font-mono text-sm text-gray-700"><%= @order.payment_reference || "—" %></p>
        </div>
        <% if @order.payment_gateway_response.present? %>
          <% gw = begin; JSON.parse(@order.payment_gateway_response); rescue; nil; end %>
          <% if gw %>
            <div class="col-span-2 pt-4 border-t border-gray-100">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-3 flex items-center gap-1.5">
                <svg style="width:0.875rem;height:0.875rem;flex-shrink:0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                </svg>
                Gateway Response
              </p>
              <div class="bg-gray-50 rounded-xl p-4 grid grid-cols-2 sm:grid-cols-3 gap-x-6 gap-y-2 text-xs">
                <% gw.each do |key, val| %>
                  <% next if val.nil? %>
                  <div>
                    <span class="block text-gray-400 uppercase tracking-wide" style="font-size:10px"><%= key.to_s.tr("_", " ") %></span>
                    <span class="font-mono font-semibold <%= key == 'status' ? 'text-green-600' : 'text-gray-700' %>"><%= val %></span>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        <% end %>
        <div>
          <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Order Date</p>
          <p class="text-gray-700"><%= @order.created_at.strftime("%B %d, %Y %I:%M %p") %></p>
        </div>
        <% if @order.paid_at %>
          <div>
            <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Paid At</p>
            <p class="text-gray-700"><%= @order.paid_at.strftime("%B %d, %Y %I:%M %p") %></p>
          </div>
        <% end %>
      </div>

      <!-- Pricing -->
      <div class="mt-6 pt-4 border-t border-gray-100 space-y-2 text-sm">
        <div class="flex justify-between text-gray-500">
          <span>Subtotal</span>
          <span>$<%= "%.2f" % @order.subtotal %></span>
        </div>
        <% if @order.discount_cents > 0 %>
          <div class="flex justify-between text-green-600">
            <span>Discount</span>
            <span>-$<%= "%.2f" % @order.discount %></span>
          </div>
        <% end %>
        <div class="flex justify-between font-bold text-gray-900 text-base pt-2 border-t border-gray-100">
          <span>Total</span>
          <span>$<%= "%.2f" % @order.total %></span>
        </div>
      </div>
    </div>

    <!-- Tickets -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100">
        <h2 class="text-base font-bold text-gray-900">Tickets (<%= @tickets.count %>)</h2>
      </div>
      <div class="divide-y divide-gray-50">
        <% @tickets.each do |ticket| %>
          <div class="px-6 py-4 flex items-center justify-between">
            <div>
              <p class="text-sm font-semibold text-gray-900"><%= ticket.ticket_type.name %></p>
              <p class="font-mono text-xs text-indigo-600 mt-1"><%= ticket.token %></p>
            </div>
            <div class="text-right">
              <% if ticket.delivered? %>
                <span class="text-xs bg-green-50 text-green-600 font-semibold px-2.5 py-1 rounded-full">Delivered</span>
              <% elsif ticket.status == "cancelled" %>
                <span class="text-xs bg-red-50 text-red-600 font-semibold px-2.5 py-1 rounded-full">Cancelled</span>
              <% else %>
                <span class="text-xs bg-gray-100 text-gray-500 font-semibold px-2.5 py-1 rounded-full"><%= ticket.status.capitalize %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Operation logs -->
  <div>
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
        <h2 class="text-sm font-bold text-gray-900">Related Operations</h2>
        <%= link_to "All logs", admin_operation_logs_path(category: "orders"), class: "text-xs text-indigo-600 hover:text-indigo-800" %>
      </div>
      <div class="divide-y divide-gray-50">
        <% if @logs.any? %>
          <% @logs.each do |log| %>
            <div class="px-4 py-3">
              <div class="flex items-center justify-between mb-1">
                <p class="text-xs font-semibold text-gray-700 truncate flex-1"><%= log.operation_name.gsub("::", " / ") %></p>
                <% if log.success? %>
                  <span class="w-2 h-2 bg-green-400 rounded-full ml-2 flex-shrink-0"></span>
                <% else %>
                  <span class="w-2 h-2 bg-red-400 rounded-full ml-2 flex-shrink-0"></span>
                <% end %>
              </div>
              <% if log.error_message.present? %>
                <p class="text-xs text-red-500 truncate"><%= log.error_message %></p>
              <% end %>
              <p class="text-xs text-gray-400"><%= log.performed_at.strftime("%b %d %H:%M:%S") %> &middot; <%= "%.1f" % log.duration_ms.to_f %>ms</p>
            </div>
          <% end %>
        <% else %>
          <div class="px-4 py-6 text-xs text-gray-400 text-center">No logs yet</div>
        <% end %>
      </div>
    </div>
  </div>
</div>
