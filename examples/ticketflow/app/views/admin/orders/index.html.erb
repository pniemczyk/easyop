<% content_for :page_title, "Orders" %>

<!-- Filters -->
<div class="flex gap-3 mb-6 flex-wrap">
  <%= link_to "All", admin_orders_path, class: "text-sm px-4 py-2 rounded-lg font-medium #{params[:status].blank? ? 'bg-indigo-600 text-white' : 'bg-white border border-gray-200 text-gray-600 hover:border-indigo-300'}" %>
  <%= link_to "Paid", admin_orders_path(status: "paid"), class: "text-sm px-4 py-2 rounded-lg font-medium #{params[:status] == 'paid' ? 'bg-green-600 text-white' : 'bg-white border border-gray-200 text-gray-600 hover:border-gray-300'}" %>
  <%= link_to "Pending", admin_orders_path(status: "pending"), class: "text-sm px-4 py-2 rounded-lg font-medium #{params[:status] == 'pending' ? 'bg-yellow-500 text-white' : 'bg-white border border-gray-200 text-gray-600 hover:border-gray-300'}" %>
  <%= link_to "Refunded", admin_orders_path(status: "refunded"), class: "text-sm px-4 py-2 rounded-lg font-medium #{params[:status] == 'refunded' ? 'bg-red-600 text-white' : 'bg-white border border-gray-200 text-gray-600 hover:border-gray-300'}" %>
</div>

<div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
  <table class="w-full">
    <thead>
      <tr class="bg-gray-50 border-b border-gray-100">
        <th class="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Customer</th>
        <th class="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Event</th>
        <th class="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Status</th>
        <th class="text-right px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Tickets</th>
        <th class="text-right px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Total</th>
        <th class="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Date</th>
        <th class="px-6 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-50">
      <% @orders.each do |order| %>
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-6 py-4">
            <p class="text-sm font-semibold text-gray-900"><%= order.name %></p>
            <p class="text-xs text-gray-400"><%= order.email %></p>
          </td>
          <td class="px-6 py-4 text-sm text-gray-600 max-w-[200px] truncate"><%= order.event.title %></td>
          <td class="px-6 py-4">
            <% status_classes = { "paid" => "bg-green-50 text-green-700", "pending" => "bg-yellow-50 text-yellow-700", "refunded" => "bg-red-50 text-red-700", "cancelled" => "bg-gray-100 text-gray-500" } %>
            <span class="text-xs font-semibold px-2.5 py-1 rounded-full <%= status_classes[order.status] || 'bg-gray-100 text-gray-600' %>">
              <%= order.status.capitalize %>
            </span>
          </td>
          <td class="px-6 py-4 text-sm text-gray-900 text-right"><%= order.tickets.count %></td>
          <td class="px-6 py-4 text-sm font-bold text-gray-900 text-right">$<%= "%.2f" % order.total %></td>
          <td class="px-6 py-4 text-xs text-gray-400"><%= order.created_at.strftime("%b %d, %Y") %></td>
          <td class="px-6 py-4 text-right">
            <%= link_to "View", admin_order_path(order), class: "text-xs text-indigo-600 hover:text-indigo-800 font-semibold" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <% if @orders.empty? %>
    <div class="py-12 text-center text-sm text-gray-400">No orders found</div>
  <% end %>
</div>
