<% content_for :page_title, "Execution Tree" %>

<div class="flex items-center gap-3 mb-6">
  <%= link_to "← All logs", admin_operation_logs_path, class: "text-sm text-gray-500 hover:text-indigo-600" %>
  <span class="text-gray-300">|</span>
  <p class="text-sm text-gray-500">
    Root operation: <span class="font-mono font-semibold text-gray-800"><%= @root_log.operation_name.gsub("::", " :: ") %></span>
    &nbsp;·&nbsp;
    Tree ID: <span class="font-mono text-xs text-gray-400"><%= @tree_id %></span>
  </p>
</div>

<%#
  Flow-tracing callout: explains what the user is looking at.
  Each row in @tree_logs shares the same root_reference_id.
  The parent_reference_id links each row to its direct caller.
%>
<div class="bg-indigo-50 border border-indigo-100 rounded-xl px-5 py-4 mb-6 text-sm text-indigo-800 space-y-1">
  <p class="font-semibold">EasyOp Flow Tracing</p>
  <p>
    All operations below share the same <code class="bg-indigo-100 px-1 rounded text-xs">root_reference_id</code>.
    Each row's <code class="bg-indigo-100 px-1 rounded text-xs">parent_reference_id</code> points to
    the <code class="bg-indigo-100 px-1 rounded text-xs">reference_id</code> of its direct caller,
    letting you reconstruct the full call tree.
  </p>
</div>

<% # Build a depth map so we can indent each operation visually.
   # Walk the tree: build a hash of reference_id → depth.
   depth_map = {}
   ref_to_log = @tree_logs.index_by(&:reference_id)

   @tree_logs.each do |log|
     depth = 0
     current = log
     while current.parent_reference_id.present?
       parent = ref_to_log[current.parent_reference_id]
       break unless parent
       depth  += 1
       current = parent
     end
     depth_map[log.id] = depth
   end
%>

<div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
  <table class="w-full">
    <thead>
      <tr class="bg-gray-50 border-b border-gray-100">
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Operation</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Status</th>
        <th class="text-right px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Duration</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Reference ID</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Parent Ref</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Result Data</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Error / Info</th>
      </tr>
    </thead>
    <tbody>
      <% @tree_logs.each do |log| %>
        <% depth = depth_map[log.id] || 0 %>
        <tr class="border-t border-gray-50 hover:bg-gray-50 transition-colors">
          <td class="px-4 py-3">
            <div class="flex items-center gap-1" style="padding-left: <%= depth * 20 %>px">
              <% if depth > 0 %>
                <span class="text-gray-300 text-xs select-none flex-shrink-0">↳</span>
              <% end %>
              <div>
                <p class="text-sm font-mono font-medium text-gray-800"><%= log.operation_name.gsub("::", " :: ") %></p>
                <% if log.parent_operation_name.present? %>
                  <p class="text-xs text-gray-400 mt-0.5">called by <span class="font-mono"><%= log.parent_operation_name.split("::").last %></span></p>
                <% end %>
              </div>
            </div>
          </td>
          <td class="px-4 py-3">
            <% if log.success? %>
              <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-green-700 bg-green-50 px-2.5 py-1 rounded-full">
                <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>OK
              </span>
            <% else %>
              <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-red-700 bg-red-50 px-2.5 py-1 rounded-full">
                <span class="w-1.5 h-1.5 bg-red-500 rounded-full"></span>Failed
              </span>
            <% end %>
          </td>
          <td class="px-4 py-3 text-xs text-gray-400 text-right font-mono whitespace-nowrap">
            <%= "%.2f" % log.duration_ms.to_f %>ms
          </td>
          <td class="px-4 py-3 text-xs font-mono text-gray-400 whitespace-nowrap">
            <span title="<%= log.reference_id %>"><%= log.reference_id&.split('-')&.first %>…</span>
          </td>
          <td class="px-4 py-3 text-xs font-mono text-gray-400 whitespace-nowrap">
            <% if log.parent_reference_id.present? %>
              <span title="<%= log.parent_reference_id %>"><%= log.parent_reference_id.split('-').first %>…</span>
            <% else %>
              <span class="text-gray-300">— root</span>
            <% end %>
          </td>
          <td class="px-4 py-3 text-xs max-w-[180px]">
            <% if log.respond_to?(:result_data) && log.result_data.present? %>
              <% parsed = JSON.parse(log.result_data) rescue nil %>
              <% if parsed %>
                <div class="space-y-0.5">
                  <% parsed.each do |k, v| %>
                    <div class="font-mono text-gray-500">
                      <span class="text-gray-400"><%= k %>:</span>
                      <span class="text-indigo-600"><%= v.is_a?(Hash) ? "#{v['class']}##{v['id']}" : v.to_s.truncate(30) %></span>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <span class="text-gray-300 font-mono text-xs"><%= log.result_data.truncate(40) %></span>
              <% end %>
            <% else %>
              <span class="text-gray-300">—</span>
            <% end %>
          </td>
          <td class="px-4 py-3 text-xs max-w-[220px]">
            <% if log.error_message.present? %>
              <span class="text-red-500 truncate block"><%= log.error_message %></span>
            <% else %>
              <span class="text-gray-300">—</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <% if @tree_logs.empty? %>
    <div class="py-12 text-center">
      <p class="text-sm text-gray-400">No logs found for this tree ID.</p>
    </div>
  <% end %>
</div>

<%# Raw tracing data — collapsible reference section %>
<details class="mt-6 group">
  <summary class="cursor-pointer text-sm text-gray-500 hover:text-gray-700 flex items-center gap-2 list-none">
    <svg class="w-4 h-4 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    Raw tracing references
  </summary>
  <div class="mt-3 bg-gray-50 rounded-xl border border-gray-100 p-4 overflow-x-auto">
    <table class="w-full text-xs font-mono">
      <thead>
        <tr class="text-gray-400 text-left border-b border-gray-200">
          <th class="pb-2 pr-4">Operation</th>
          <th class="pb-2 pr-4">reference_id</th>
          <th class="pb-2 pr-4">parent_reference_id</th>
          <th class="pb-2">root_reference_id</th>
        </tr>
      </thead>
      <tbody class="text-gray-600">
        <% @tree_logs.each do |log| %>
          <tr class="border-t border-gray-100">
            <td class="py-1.5 pr-4 text-gray-800"><%= log.operation_name.split("::").last %></td>
            <td class="py-1.5 pr-4"><%= log.reference_id %></td>
            <td class="py-1.5 pr-4"><%= log.parent_reference_id.presence || "nil" %></td>
            <td class="py-1.5"><%= log.root_reference_id %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</details>
