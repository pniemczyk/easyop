<% content_for :page_title, "Events" %>

<div class="flex items-center justify-between mb-6">
  <div></div>
  <%= link_to new_admin_event_path, class: "bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors flex items-center gap-2" do %>
    <svg style="width:1rem;height:1rem;flex-shrink:0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    New Event
  <% end %>
</div>

<div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
  <table class="w-full">
    <thead>
      <tr class="bg-gray-50 border-b border-gray-100">
        <th class="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Event</th>
        <th class="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Date</th>
        <th class="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Status</th>
        <th class="text-right px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Tickets Sold</th>
        <th class="text-right px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Revenue</th>
        <th class="px-6 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-50">
      <% @events.each do |event| %>
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-6 py-4">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg flex-shrink-0" style="background: <%= event.cover_color %>"></div>
              <div>
                <p class="text-sm font-semibold text-gray-900"><%= event.title %></p>
                <p class="text-xs text-gray-400"><%= event.venue %></p>
              </div>
            </div>
          </td>
          <td class="px-6 py-4 text-sm text-gray-600">
            <%= event.starts_at.strftime("%b %d, %Y") %>
          </td>
          <td class="px-6 py-4">
            <% if event.published? %>
              <span class="inline-flex items-center gap-1 bg-green-50 text-green-700 text-xs font-semibold px-2.5 py-1 rounded-full">
                <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>
                Published
              </span>
            <% else %>
              <span class="inline-flex items-center gap-1 bg-gray-100 text-gray-500 text-xs font-semibold px-2.5 py-1 rounded-full">
                <span class="w-1.5 h-1.5 bg-gray-400 rounded-full"></span>
                Draft
              </span>
            <% end %>
          </td>
          <td class="px-6 py-4 text-sm text-gray-900 text-right font-medium"><%= event.total_tickets_sold %></td>
          <td class="px-6 py-4 text-sm font-bold text-gray-900 text-right">$<%= "%.2f" % (event.total_revenue_cents / 100.0) %></td>
          <td class="px-6 py-4 text-right">
            <%= link_to "View", admin_event_path(event), class: "text-xs text-indigo-600 hover:text-indigo-800 font-semibold" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <% if @events.empty? %>
    <div class="py-12 text-center text-sm text-gray-400">No events yet. <%= link_to "Create one", new_admin_event_path, class: "text-indigo-600 font-medium" %></div>
  <% end %>
</div>
