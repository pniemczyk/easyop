<% content_for :page_title, "Edit Event" %>

<div class="max-w-2xl">
  <%= link_to "← Back to event", admin_event_path(@event), class: "text-sm text-gray-500 hover:text-indigo-600 mb-6 inline-block" %>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8">
    <h2 class="text-xl font-bold text-gray-900 mb-6">Edit Event</h2>

    <%= form_with model: [:admin, @event], class: "space-y-5" do |f| %>
      <div>
        <%= f.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :title, required: true,
            class: "w-full border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      </div>
      <div>
        <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_area :description, rows: 4,
            class: "w-full border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :venue, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :venue,
              class: "w-full border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
        <div>
          <%= f.label :location, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :location,
              class: "w-full border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :starts_at, "Start Date & Time", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.datetime_local_field :starts_at, required: true,
              class: "w-full border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
        <div>
          <%= f.label :ends_at, "End Date & Time", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.datetime_local_field :ends_at,
              class: "w-full border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
      </div>
      <div>
        <%= f.label :cover_color, "Cover Color", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <div class="flex items-center gap-3">
          <%= f.color_field :cover_color,
              class: "w-12 h-10 border border-gray-200 rounded-lg cursor-pointer" %>
          <span class="text-sm text-gray-500">Choose an accent color</span>
        </div>
      </div>
      <div class="flex gap-3 pt-2">
        <%= f.submit "Update Event", class: "bg-indigo-600 hover:bg-indigo-700 text-white font-bold px-6 py-3 rounded-xl transition-colors cursor-pointer" %>
        <%= link_to "Cancel", admin_event_path(@event), class: "text-sm text-gray-500 hover:text-gray-700 py-3 px-4" %>
      </div>
    <% end %>
  </div>
</div>
