<% content_for :page_title, @event.title %>

<div class="flex items-center justify-between mb-6">
  <%= link_to "← All events", admin_events_path, class: "text-sm text-gray-500 hover:text-indigo-600" %>
  <div class="flex items-center gap-3">
    <% unless @event.published? %>
      <%= button_to "Publish Event", publish_admin_event_path(@event), method: :post,
          class: "bg-green-600 hover:bg-green-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors" %>
    <% else %>
      <span class="text-sm bg-green-100 text-green-700 font-semibold px-3 py-1.5 rounded-lg">Published</span>
    <% end %>
    <%= link_to "Edit", edit_admin_event_path(@event), class: "text-sm bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold px-4 py-2 rounded-lg transition-colors" %>
    <%= button_to "Delete", admin_event_path(@event), method: :delete,
        data: { turbo_confirm: "Are you sure? This cannot be undone." },
        class: "text-sm bg-red-50 hover:bg-red-100 text-red-600 font-semibold px-4 py-2 rounded-lg transition-colors" %>
  </div>
</div>

<!-- Event header -->
<div class="rounded-2xl overflow-hidden mb-8 h-32 relative" style="background: linear-gradient(135deg, <%= @event.cover_color %>, <%= @event.cover_color %>99)">
  <div class="absolute inset-0 bg-black/20 flex items-end p-6">
    <div>
      <h1 class="text-2xl font-bold text-white"><%= @event.title %></h1>
      <p class="text-white/70 text-sm"><%= @event.starts_at.strftime("%B %d, %Y") %> &middot; <%= @event.venue %></p>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
  <!-- Ticket Types -->
  <div>
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100">
        <h2 class="text-base font-bold text-gray-900">Ticket Types</h2>
      </div>

      <% if @ticket_types.any? %>
        <div class="divide-y divide-gray-50">
          <% @ticket_types.each do |tt| %>
            <div class="px-6 py-4 flex items-center justify-between">
              <div>
                <p class="text-sm font-semibold text-gray-900"><%= tt.name %></p>
                <p class="text-xs text-gray-400"><%= tt.sold_count %>/<%= tt.quantity %> sold &middot; $<%= "%.2f" % tt.price %></p>
              </div>
              <div class="flex items-center gap-2">
                <%= button_to admin_event_ticket_type_path(@event, tt), method: :delete,
                    data: { turbo_confirm: "Remove this ticket type?" },
                    class: "text-xs text-red-500 hover:text-red-700 px-2 py-1 rounded" do %>
                  Remove
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="px-6 py-4 text-sm text-gray-400">No ticket types yet.</div>
      <% end %>

      <!-- Add ticket type form -->
      <div class="px-6 py-5 bg-gray-50 border-t border-gray-100">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Add Ticket Type</p>
        <%= form_with url: admin_event_ticket_types_path(@event), method: :post, class: "space-y-3" do |f| %>
          <div>
            <input type="text" name="ticket_type[name]" required placeholder="e.g. General Admission"
                   class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
          </div>
          <div>
            <input type="text" name="ticket_type[description]" placeholder="Optional description"
                   class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="text-xs text-gray-500 mb-1 block">Price (cents, 0 = free)</label>
              <input type="number" name="ticket_type[price_cents]" min="0" value="2500" required
                     class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
            </div>
            <div>
              <label class="text-xs text-gray-500 mb-1 block">Quantity</label>
              <input type="number" name="ticket_type[quantity]" min="1" value="100" required
                     class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
            </div>
          </div>
          <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold py-2 rounded-lg transition-colors">
            Add Ticket Type
          </button>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Recent orders -->
  <div>
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
        <h2 class="text-base font-bold text-gray-900">Recent Orders</h2>
        <%= link_to "All orders", admin_orders_path(event_id: @event.id), class: "text-xs text-indigo-600 hover:text-indigo-800 font-medium" %>
      </div>
      <% if @orders.any? %>
        <div class="divide-y divide-gray-50">
          <% @orders.each do |order| %>
            <div class="px-6 py-3 flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-gray-900"><%= order.name %></p>
                <p class="text-xs text-gray-400"><%= order.email %></p>
              </div>
              <div class="text-right">
                <p class="text-sm font-bold text-gray-900">$<%= "%.2f" % order.total %></p>
                <%= link_to "View", admin_order_path(order), class: "text-xs text-indigo-600 hover:text-indigo-800" %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="px-6 py-8 text-center text-sm text-gray-400">No paid orders yet</div>
      <% end %>
    </div>
  </div>
</div>
