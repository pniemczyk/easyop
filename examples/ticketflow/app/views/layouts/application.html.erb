<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "TicketFlow — Buy Event Tickets" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 text-gray-900 min-h-screen">
    <!-- Navigation -->
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50 shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <div class="flex items-center gap-8">
            <%= link_to root_path, class: "flex items-center gap-2" do %>
              <div class="w-8 h-8 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-lg flex items-center justify-center">
                <span class="text-white font-bold text-sm">T</span>
              </div>
              <span class="text-xl font-bold text-gray-900">TicketFlow</span>
            <% end %>
            <%= link_to "Browse Events", events_path, class: "text-gray-600 hover:text-indigo-600 font-medium transition-colors" %>
          </div>
          <div class="flex items-center gap-3">
            <% if admin? %>
              <%= link_to "Admin", admin_root_path, class: "text-xs bg-amber-100 text-amber-700 px-3 py-1 rounded-full font-semibold hover:bg-amber-200 transition-colors" %>
            <% end %>
            <% if logged_in? %>
              <span class="text-sm text-gray-600">Hi, <%= current_user.name.split(" ").first %></span>
              <%= link_to "Sign out", logout_path, data: { turbo_method: :delete }, class: "text-sm text-gray-500 hover:text-gray-700" %>
            <% else %>
              <%= link_to "Sign in", login_path, class: "text-sm text-gray-600 hover:text-indigo-600 font-medium" %>
              <%= link_to "Register", register_path, class: "text-sm bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700 transition-colors font-medium" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <!-- Flash messages -->
    <%= render "shared/flash" %>

    <!-- Main content -->
    <main>
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-gray-200 mt-16 py-8">
      <div class="max-w-7xl mx-auto px-4 text-center text-sm text-gray-500">
        <p>TicketFlow &mdash; Demo app powered by <strong class="text-indigo-600">EasyOp</strong></p>
      </div>
    </footer>
  </body>
</html>
