<% content_for :title, "Sign In" %>

<div class="min-h-screen flex items-center justify-center py-12 px-4">
  <div class="max-w-md w-full">
    <!-- Logo -->
    <div class="text-center mb-8">
      <div class="w-14 h-14 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg shadow-indigo-200">
        <span class="text-white font-bold text-2xl">T</span>
      </div>
      <h2 class="text-3xl font-extrabold text-gray-900">Sign in to TicketFlow</h2>
      <p class="text-gray-500 mt-2">Welcome back!</p>
    </div>

    <div class="bg-white shadow-sm rounded-2xl border border-gray-100 p-8">
      <%= form_with url: login_path, method: :post, class: "space-y-5" do |f| %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Email address</label>
          <input type="email" name="email" required autocomplete="email"
                 class="w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                 placeholder="you@example.com">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
          <input type="password" name="password" required autocomplete="current-password"
                 class="w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                 placeholder="••••••••">
        </div>
        <button type="submit"
                class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 rounded-xl transition-colors">
          Sign In
        </button>
      <% end %>

      <div class="mt-6 text-center text-sm text-gray-500">
        Don't have an account?
        <%= link_to "Create one", register_path, class: "text-indigo-600 hover:text-indigo-800 font-semibold" %>
      </div>

      <!-- Demo credentials -->
      <div class="mt-6 p-4 bg-amber-50 rounded-xl border border-amber-100">
        <p class="text-xs font-semibold text-amber-700 mb-2">Demo Credentials</p>
        <p class="text-xs text-amber-600">Admin: admin@ticketflow.com / password123</p>
        <p class="text-xs text-amber-600">User: user@ticketflow.com / password123</p>
      </div>
    </div>
  </div>
</div>
