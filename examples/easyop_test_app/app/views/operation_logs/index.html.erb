<% content_for :title, "Operation Logs" %>

<div style="display: flex; align-items: baseline; gap: 1rem; margin-bottom: 0.5rem;">
  <h1 style="margin: 0;">Operation Logs</h1>
  <small style="color: #888;">Recording plugin — every execution persisted to DB</small>
</div>

<%# ── Stats bar ─────────────────────────────────────────────────────────── %>
<div style="display: flex; gap: 1rem; margin-bottom: 1.25rem; flex-wrap: wrap;">
  <% [
    ["Total",     @stats[:total],        "#333", "#f5f5f5"],
    ["Succeeded", @stats[:succeeded],    "#1a6e1a", "#efffef"],
    ["Failed",    @stats[:failed],       "#c00", "#fff0f0"],
    ["Encrypted", @stats[:encrypted],    "#5a5aaa", "#f0f0ff"],
    ["Avg ms",    @stats[:avg_duration] || "—", "#555", "#fffbe8"],
  ].each do |label, val, color, bg| %>
    <div style="background: <%= bg %>; border: 1px solid <%= color %>22; border-radius: 6px; padding: 0.4rem 0.9rem; text-align: center; min-width: 80px;">
      <div style="font-size: 1.4rem; font-weight: bold; color: <%= color %>;"><%= val %></div>
      <div style="font-size: 0.7rem; color: #888; text-transform: uppercase; letter-spacing: 0.05em;"><%= label %></div>
    </div>
  <% end %>
</div>

<%# ── Filter bar ─────────────────────────────────────────────────────────── %>
<%= form_tag operation_logs_path, method: :get, style: "display:flex; gap:0.5rem; align-items:center; margin-bottom:1rem; flex-wrap:wrap;" do %>
  <%= select_tag :operation,
        options_for_select([["All operations", ""]] + @operation_names.map { |n| [n, n] }, @filter_operation),
        style: "padding: 0.35rem 0.5rem; font-size: 0.85rem; border: 1px solid #ccc; border-radius: 4px;" %>

  <% [["all","All"],["success","✓ Success"],["failed","✗ Failed"]].each do |val, label| %>
    <%= link_to label,
          operation_logs_path(operation: @filter_operation, status: (val == "all" ? nil : val)),
          style: "padding: 0.3rem 0.75rem; font-size: 0.8rem; border-radius: 4px; text-decoration: none;
                  background: #{@filter_status.to_s == val || (val == 'all' && @filter_status.blank?) ? '#333' : '#eee'};
                  color: #{@filter_status.to_s == val || (val == 'all' && @filter_status.blank?) ? 'white' : '#555'};" %>
  <% end %>

  <%= submit_tag "Filter", style: "padding: 0.35rem 0.9rem; font-size: 0.85rem; background: #555; color: white; border: none; border-radius: 4px; cursor: pointer;" %>

  <% if @filter_operation.present? || @filter_status.present? %>
    <%= link_to "✕ Clear", operation_logs_path, style: "font-size: 0.8rem; color: #888;" %>
  <% end %>
<% end %>

<% if @logs.empty? %>
  <p style="color: #888; padding: 2rem; text-align: center; border: 1px dashed #ddd; border-radius: 6px;">
    No operation logs match the current filter.
    <%= link_to "Clear filters", operation_logs_path %> or
    run some operations (try <%= link_to "Transfer Credits", new_transfer_path %> or
    <%= link_to "Purchase Access", new_purchase_path %>).
  </p>
<% else %>
  <table style="width: 100%; border-collapse: collapse; font-size: 0.85rem;">
    <thead>
      <tr style="background: #f5f5f5; text-align: left; border-bottom: 2px solid #ddd;">
        <th style="padding: 0.5rem;">Operation</th>
        <th style="padding: 0.5rem; width: 60px;">Status</th>
        <th style="padding: 0.5rem; width: 60px;">ms</th>
        <th style="padding: 0.5rem;">Params</th>
        <th style="padding: 0.5rem;">Result</th>
        <th style="padding: 0.5rem; width: 90px;">Tree</th>
        <th style="padding: 0.5rem; width: 130px;">Time</th>
      </tr>
    </thead>
    <tbody>
      <% @logs.each do |log| %>
        <%
          is_root  = log.root?
          has_enc  = log.has_encrypted_params?
          p_parsed = log.parsed_params
          r_parsed = log.parsed_result
          row_bg   = log.success? ? "white" : "#fff8f8"
        %>
        <tr style="border-bottom: 1px solid #eee; background: <%= row_bg %>; vertical-align: top;">
          <%# Operation name cell %>
          <td style="padding: 0.5rem; font-family: monospace; font-size: 0.8rem;">
            <% unless is_root %>
              <span style="color: #ccc; margin-right: 0.2rem;">↳</span>
            <% end %>
            <% if is_root && log.root_reference_id.present? %>
              <%= link_to log.operation_name, operation_log_path(log),
                    style: "color: #333; font-weight: bold; text-decoration: none;" %>
            <% else %>
              <span style="color: #555;"><%= log.operation_name %></span>
            <% end %>
            <% if has_enc %>
              <span title="This log has encrypted params (encrypt_params DSL)"
                    style="margin-left: 0.3rem; font-size: 0.65rem; background: #5a5aaa; color: white;
                           padding: 1px 5px; border-radius: 3px; font-family: sans-serif; vertical-align: middle;">
                🔒 enc
              </span>
            <% end %>
            <% if log.parent_operation_name.present? %>
              <div style="font-size: 0.7rem; color: #aaa; font-family: sans-serif;">
                via <%= log.parent_operation_name.split("::").last %>
              </div>
            <% end %>
          </td>

          <%# Status badge %>
          <td style="padding: 0.5rem;">
            <% if log.success? %>
              <span style="background: #6c6; color: white; font-size: 0.7rem; padding: 2px 6px; border-radius: 3px;">ok</span>
            <% else %>
              <span style="background: #c44; color: white; font-size: 0.7rem; padding: 2px 6px; border-radius: 3px;">FAIL</span>
            <% end %>
            <% if log.error_message.present? %>
              <div style="font-size: 0.7rem; color: #c00; margin-top: 2px; max-width: 120px; word-break: break-word;">
                <%= log.error_message.truncate(60) %>
              </div>
            <% end %>
          </td>

          <%# Duration %>
          <td style="padding: 0.5rem; font-family: monospace; color: #666; font-size: 0.8rem;">
            <%= log.duration_ms ? log.duration_ms.round(1) : "—" %>
          </td>

          <%# Params data cell with encrypted badges %>
          <td style="padding: 0.5rem; font-size: 0.75rem; max-width: 220px;">
            <% if p_parsed.any? %>
              <% p_parsed.each do |k, v| %>
                <div style="display: flex; gap: 0.25rem; align-items: baseline; margin-bottom: 1px; flex-wrap: wrap;">
                  <span style="color: #888; font-family: monospace;"><%= k %>:</span>
                  <% if v.is_a?(Hash) && v.key?("$easyop_encrypted") %>
                    <span style="background: #5a5aaa; color: white; font-size: 0.65rem; padding: 1px 5px; border-radius: 3px;"
                          title="Value encrypted via encrypt_params DSL. Stored as { &quot;$easyop_encrypted&quot;: &quot;...ciphertext...&quot; }. Decrypt with Easyop::SimpleCrypt.decrypt_marker(value)">
                      🔒 encrypted
                    </span>
                  <% elsif v == "[FILTERED]" %>
                    <span style="background: #f0a020; color: white; font-size: 0.65rem; padding: 1px 5px; border-radius: 3px;"
                          title="Value filtered via filter_params DSL or built-in FILTERED_KEYS (password, token, etc.)">
                      [FILTERED]
                    </span>
                  <% elsif v.is_a?(Hash) && v["class"] %>
                    <span style="color: #336; font-family: monospace; font-size: 0.72rem;"><%= v["class"] %>#<%= v["id"] %></span>
                  <% else %>
                    <span style="color: #444; font-family: monospace; font-size: 0.72rem;"><%= v.to_s.truncate(28) %></span>
                  <% end %>
                </div>
              <% end %>
            <% else %>
              <span style="color: #ccc;">—</span>
            <% end %>
          </td>

          <%# Result data cell %>
          <td style="padding: 0.5rem; font-size: 0.75rem; max-width: 180px;">
            <% if r_parsed.any? %>
              <% r_parsed.each do |k, v| %>
                <div style="display: flex; gap: 0.25rem; align-items: baseline; margin-bottom: 1px;">
                  <span style="color: #888; font-family: monospace;"><%= k %>:</span>
                  <% if v.is_a?(Hash) && v["class"] %>
                    <span style="color: #2a5a2a; font-family: monospace; font-size: 0.72rem;"><%= v["class"] %>#<%= v["id"] %></span>
                  <% else %>
                    <span style="color: #444; font-family: monospace; font-size: 0.72rem;"><%= v.to_s.truncate(25) %></span>
                  <% end %>
                </div>
              <% end %>
            <% else %>
              <span style="color: #ccc;">—</span>
            <% end %>
          </td>

          <%# Tree link %>
          <td style="padding: 0.5rem; font-family: monospace; font-size: 0.72rem; color: #999;">
            <% if is_root && log.root_reference_id.present? %>
              <%= link_to "#{log.root_reference_id.split('-').first}…",
                    operation_log_path(log),
                    style: "color: #5a5aaa; text-decoration: none;" %>
            <% elsif log.root_reference_id.present? %>
              <span style="color: #ccc;" title="<%= log.root_reference_id %>"><%= log.root_reference_id.split('-').first %>…</span>
            <% else %>
              —
            <% end %>
          </td>

          <%# Time %>
          <td style="padding: 0.5rem; font-size: 0.75rem; color: #888;">
            <%= log.performed_at.strftime("%m-%d %H:%M:%S") %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div style="margin-top: 1rem; font-size: 0.78rem; color: #888; line-height: 1.6;">
    <strong>Legend:</strong>
    <span style="background: #5a5aaa; color: white; font-size: 0.65rem; padding: 1px 5px; border-radius: 3px;">🔒 enc</span> — value encrypted via <code>encrypt_params</code> DSL (stored as <code>{ "$easyop_encrypted" =&gt; "..." }</code>) ·
    <span style="background: #f0a020; color: white; font-size: 0.65rem; padding: 1px 5px; border-radius: 3px;">[FILTERED]</span> — value scrubbed via <code>filter_params</code> or built-in key list ·
    Click a root operation name to see the full execution tree.
    Try <%= link_to "Purchase Access", new_purchase_path %> to generate an encrypted params log.
  </div>
<% end %>
