<% content_for :title, "Execution Tree" %>

<p><a href="<%= operation_logs_path %>" style="color: #555; font-size: 0.9rem;">← All logs</a></p>

<h1>Execution Tree</h1>
<p style="font-size: 0.9rem; color: #555;">
  Root operation: <strong style="font-family: monospace;"><%= @root_log.operation_name %></strong>
  &nbsp;·&nbsp;
  Tree ID: <span style="font-family: monospace; font-size: 0.8rem; color: #999;"><%= @tree_id %></span>
</p>

<p style="background: #f0f4ff; border: 1px solid #c8d4f0; padding: 0.75rem 1rem; border-radius: 4px; font-size: 0.85rem; color: #334;">
  All operations below share the same <code>root_reference_id</code>.
  Each row's <code>parent_reference_id</code> points to its direct caller's <code>reference_id</code>,
  letting you reconstruct the full call tree. Click an entry's Tree ID in the
  <a href="<%= operation_logs_path %>">logs list</a> to reach this view.
</p>

<%
  # Build depth map by walking parent_reference_id links.
  depth_map   = {}
  ref_to_log  = @tree_logs.index_by(&:reference_id)

  @tree_logs.each do |log|
    depth   = 0
    current = log
    while current.parent_reference_id.present?
      parent = ref_to_log[current.parent_reference_id]
      break unless parent
      depth  += 1
      current = parent
    end
    depth_map[log.id] = depth
  end
%>

<% if @tree_logs.empty? %>
  <p style="color: #888;">No logs found for this tree ID.</p>
<% else %>
  <table style="width: 100%; border-collapse: collapse; font-size: 0.85rem; margin-top: 1rem;">
    <thead>
      <tr style="background: #f5f5f5; text-align: left;">
        <th style="padding: 0.5rem; border-bottom: 2px solid #ddd;">Operation</th>
        <th style="padding: 0.5rem; border-bottom: 2px solid #ddd;">Status</th>
        <th style="padding: 0.5rem; border-bottom: 2px solid #ddd;">Duration</th>
        <th style="padding: 0.5rem; border-bottom: 2px solid #ddd;">Result Data</th>
        <th style="padding: 0.5rem; border-bottom: 2px solid #ddd;">Reference ID</th>
        <th style="padding: 0.5rem; border-bottom: 2px solid #ddd;">Parent Ref</th>
        <th style="padding: 0.5rem; border-bottom: 2px solid #ddd;">Error</th>
      </tr>
    </thead>
    <tbody>
      <% @tree_logs.each do |log| %>
        <% depth = depth_map[log.id] || 0 %>
        <tr style="border-bottom: 1px solid #eee;">
          <td style="padding: 0.5rem; font-family: monospace; padding-left: <%= 0.5 + depth * 1.25 %>rem;">
            <% if depth > 0 %>
              <span style="color: #bbb; margin-right: 0.25rem;">↳</span>
            <% end %>
            <%= log.operation_name %>
            <% if log.parent_operation_name.present? && depth > 0 %>
              <br><small style="color: #aaa; font-size: 0.75rem;">called by <%= log.parent_operation_name.split("::").last %></small>
            <% end %>
          </td>
          <td style="padding: 0.5rem;">
            <% if log.success? %>
              <span class="badge badge-published">ok</span>
            <% else %>
              <span class="badge badge-draft">FAILED</span>
            <% end %>
          </td>
          <td style="padding: 0.5rem; font-family: monospace; font-size: 0.8rem; color: #666;">
            <%= log.duration_ms ? "#{log.duration_ms.round(2)}ms" : "—" %>
          </td>
          <td style="padding: 0.5rem; font-family: monospace; font-size: 0.75rem; color: #444; max-width: 180px;">
            <% if log.respond_to?(:result_data) && log.result_data.present? %>
              <% parsed = JSON.parse(log.result_data) rescue nil %>
              <% if parsed %>
                <% parsed.each do |k, v| %>
                  <div><span style="color: #888;"><%= k %>:</span>
                  <span style="color: #336;"><%= v.is_a?(Hash) ? "#{v['class']}##{v['id']}" : v.to_s.truncate(25) %></span></div>
                <% end %>
              <% else %>
                <%= log.result_data.truncate(40) %>
              <% end %>
            <% else %>
              <span style="color: #ccc;">—</span>
            <% end %>
          </td>
          <td style="padding: 0.5rem; font-family: monospace; font-size: 0.75rem; color: #999;">
            <span title="<%= log.reference_id %>"><%= log.reference_id&.split('-')&.first %>…</span>
          </td>
          <td style="padding: 0.5rem; font-family: monospace; font-size: 0.75rem; color: #999;">
            <% if log.parent_reference_id.present? %>
              <span title="<%= log.parent_reference_id %>"><%= log.parent_reference_id.split('-').first %>…</span>
            <% else %>
              <span style="color: #ccc;">— root</span>
            <% end %>
          </td>
          <td style="padding: 0.5rem; color: #c00; font-size: 0.8rem; max-width: 160px;">
            <%= log.error_message.presence || "—" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <details style="margin-top: 1.5rem;">
    <summary style="cursor: pointer; font-size: 0.85rem; color: #666;">Raw tracing references</summary>
    <table style="width: 100%; border-collapse: collapse; font-size: 0.75rem; font-family: monospace; margin-top: 0.5rem; background: #fafafa; border: 1px solid #eee;">
      <thead>
        <tr style="text-align: left; color: #888; border-bottom: 1px solid #ddd;">
          <th style="padding: 0.4rem;">Operation</th>
          <th style="padding: 0.4rem;">reference_id</th>
          <th style="padding: 0.4rem;">parent_reference_id</th>
          <th style="padding: 0.4rem;">root_reference_id</th>
        </tr>
      </thead>
      <tbody>
        <% @tree_logs.each do |log| %>
          <tr style="border-bottom: 1px solid #eee;">
            <td style="padding: 0.4rem; color: #333;"><%= log.operation_name.split("::").last %></td>
            <td style="padding: 0.4rem;"><%= log.reference_id %></td>
            <td style="padding: 0.4rem;"><%= log.parent_reference_id.presence || "nil" %></td>
            <td style="padding: 0.4rem;"><%= log.root_reference_id %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </details>
<% end %>
