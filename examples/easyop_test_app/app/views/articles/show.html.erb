<% content_for :title, @article.title %>

<article>
  <h1>
    <%= @article.title %>
    <% if @article.published? %>
      <span class="badge badge-published">published</span>
    <% else %>
      <span class="badge badge-draft">draft</span>
    <% end %>
  </h1>

  <p><small>By <%= @article.user.name %>
    <% if @article.published? %>
      &mdash; Published <%= @article.published_at.strftime("%B %d, %Y at %I:%M %p") %>
    <% else %>
      &mdash; Draft, created <%= @article.created_at.strftime("%B %d, %Y") %>
    <% end %>
  </small></p>

  <div style="white-space: pre-wrap; line-height: 1.6;"><%= @article.body %></div>
</article>

<div style="margin-top: 2rem;">
  <% if logged_in? && @article.user == current_user %>
    <% unless @article.published? %>
      <%= button_to "Publish Article", publish_article_path(@article), method: :post, class: "btn" %>
      &nbsp;
      <%= link_to "Broadcast & Publish", new_article_broadcast_path(@article), class: "btn" %>
    <% end %>
    <%= button_to "Delete", article_path(@article), method: :delete, class: "btn btn-danger", data: { confirm: "Are you sure?" } %>
  <% end %>
  <%= link_to "Back to Articles", articles_path, class: "btn" %>
</div>
